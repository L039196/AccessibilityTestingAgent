    "clean": "rm -rf results/ accessibility_results/ screenshots/ *.html *.json *.md",
    "clean:all": "rm -rf results/ accessibility_results/ screenshots/ __pycache__ .pytest_cache *.html *.json *.md venv/.cache",
    "clean:results": "rm -rf results/ accessibility_results/",
    "clean:screenshots": "rm -rf screenshots/",
    "clean:temp": "find . -name '*.DS_Store' -delete && find . -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true",
    
    "report": "open results/desktop/accessibility_report_desktop.html",
    "report:desktop": "open results/desktop/accessibility_report_desktop.html",
    "report:mobile-ios": "open results/mobile/ios/accessibility_report_mobile_ios.html",
    "report:mobile-android": "open results/mobile/android/accessibility_report_mobile_android.html",
    "report:tablet-ios": "open results/tablet/ios/accessibility_report_tablet_ios.html",
    "report:tablet-android": "open results/tablet/android/accessibility_report_tablet_android.html",
    
    "install": "python -m venv venv && source venv/bin/activate && pip install -r requirements.txt && npx playwright install",
    "install:python": "pip install -r requirements.txt",
    "install:playwright": "npx playwright install",
    
    "verify:wcag22": "echo 'WCAG 2.2 Configuration Verified:' && grep -A 10 'wcag22' config.json",
    "verify:env": "python --version && pip list | grep -E '(playwright|axe|beautifulsoup4)'",
    
    "status": "ls -la results/ accessibility_results/ 2>/dev/null || echo 'No results found'",
    "cleanup": "bash cleanup.sh",
    
    "info": "echo '♿ AI Accessibility Testing Agent v2.0.0 - Desktop, Mobile, Tablet'",
    "info:usage": "echo '🎯 Quick Start: npm run test:desktop:headed | npm run test:mobile:headed | npm run test:tablet:headed'",
    "info:headless": "echo '⚡ Headless Mode: npm run test:desktop:headless | npm run test:mobile:headless | npm run test:tablet:headless'",
    "info:sequential": "echo '🔄 Sequential Mode: npm run test:desktop:sequential | npm run test:mobile:sequential | npm run test:tablet:sequential'",
    "info:workers": "echo '⚙️ Worker Control: npm run test:parallel:conservative | npm run test:parallel:moderate | npm run test:parallel:aggressive'",
    "info:wcag": "echo '📋 WCAG 2.2: npm run test:wcag22:all:headed | npm run verify:wcag22'",
    
    "help": "npm run info && npm run info:usage && npm run info:headless && npm run info:sequential && npm run info:workers && npm run info:wcag"
