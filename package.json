{
  "name": "accessibility-test-agent",
  "version": "1.0.0",
  "description": "Automated Accessibility Testing Agent with multi-device support",
  "scripts": {
    "test": "./venv/bin/python main_parallel.py --csv urls_to_test.csv",
    "test:desktop": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device desktop",
    "test:mobile-ios": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-ios",
    "test:mobile-android": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android",
    "test:tablet-ios": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-ios",
    "test:tablet-android": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-android",
    "test:all": "./venv/bin/python main_parallel.py --csv urls_to_test.csv",
    "test:csv": "./venv/bin/python main_parallel.py --csv urls_to_test.csv",
    "test:csv:desktop": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device desktop",
    "test:csv:mobile-ios": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-ios",
    "test:csv:mobile-android": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android",
    "test:csv:tablet-ios": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-ios",
    "test:csv:tablet-android": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-android",
    "test:iphone15": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-ios --device-name 'iPhone 15 Pro'",
    "test:iphone14": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-ios --device-name 'iPhone 14'",
    "test:iphone13": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-ios --device-name 'iPhone 13'",
    "test:iphone-se": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-ios --device-name 'iPhone SE'",
    "test:ipad-pro": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-ios --device-name 'iPad Pro 12.9'",
    "test:ipad-air": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-ios --device-name 'iPad Air'",
    "test:ipad": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-ios --device-name 'iPad'",
    "test:ipad-mini": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-ios --device-name 'iPad Mini'",
    "test:galaxy-s24": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android --device-name 'Samsung Galaxy S24 Ultra'",
    "test:galaxy-s23": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android --device-name 'Samsung Galaxy S23'",
    "test:galaxy-s21": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android --device-name 'Samsung Galaxy S21'",
    "test:pixel8": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android --device-name 'Google Pixel 8'",
    "test:pixel7": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android --device-name 'Google Pixel 7'",
    "test:oneplus11": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device mobile-android --device-name 'OnePlus 11'",
    "test:galaxy-tab-s9": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-android --device-name 'Samsung Galaxy Tab S9'",
    "test:galaxy-tab": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-android --device-name 'Samsung Galaxy Tab'",
    "test:surface-pro": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-android --device-name 'Surface Pro'",
    "test:fire-hd": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device tablet-android --device-name 'Amazon Fire HD 10'",
    "test:chrome-desktop": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device desktop --device-name 'Chrome 1920x1080'",
    "test:safari-desktop": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device desktop --device-name 'Safari 1440x900'",
    "test:edge-desktop": "./venv/bin/python main_parallel.py --csv urls_to_test.csv --device desktop --device-name 'Edge 1366x768'",
    "test:ios-mobile": "npm run test:iphone15 && npm run test:iphone14 && npm run test:iphone13",
    "test:ios-tablets": "npm run test:ipad-pro && npm run test:ipad-air && npm run test:ipad",
    "test:android-mobile": "npm run test:galaxy-s24 && npm run test:pixel8 && npm run test:galaxy-s21",
    "test:android-tablets": "npm run test:galaxy-tab-s9 && npm run test:surface-pro",
    "test:all-ios": "npm run test:mobile-ios && npm run test:tablet-ios",
    "test:all-android": "npm run test:mobile-android && npm run test:tablet-android",
    "test:all-mobile": "npm run test:mobile-ios && npm run test:mobile-android",
    "test:all-tablets": "npm run test:tablet-ios && npm run test:tablet-android",
    "test:popular-ios": "npm run test:iphone15 && npm run test:ipad-pro",
    "test:popular-android": "npm run test:galaxy-s24 && npm run test:pixel8 && npm run test:galaxy-tab-s9",
    "test:desktop-browsers": "npm run test:chrome-desktop && npm run test:safari-desktop && npm run test:edge-desktop",
    "cleanup": "bash cleanup.sh",
    "clean": "rm -rf results/ screenshots/ *.html *.json *.md",
    "clean:results": "rm -rf results/",
    "clean:temp": "find . -name '*.DS_Store' -delete && find . -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true",
    "view:mobile-ios": "open results/mobile/ios/accessibility_report_mobile_ios.html",
    "view:mobile-android": "open results/mobile/android/accessibility_report_mobile_android.html",
    "view:tablet-ios": "open results/tablet/ios/accessibility_report_tablet_ios.html",
    "view:tablet-android": "open results/tablet/android/accessibility_report_tablet_android.html",
    "view:desktop": "open results/desktop/accessibility_report_desktop.html"
    },
  "keywords": ["accessibility", "testing", "axe-core", "automation", "mobile", "tablet", "wcag"],
  "author": "Accessibility Testing Agent",
  "license": "MIT"
}
