# ============================================================================
# AWS S3 CONFIGURATION
# ============================================================================
# Set these environment variables to enable S3 storage for accessibility reports

# Enable S3 Storage (true/false)
ENABLE_S3_STORAGE=false

# AWS Credentials
# Get these from AWS Console → IAM → Users → Security Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# S3 Bucket Configuration
S3_BUCKET_NAME=accessibility-testing-reports
S3_REGION=us-east-1

# Optional Settings
S3_AUTO_CLEANUP_LOCAL=true
S3_PRESIGNED_URL_EXPIRY=604800

# ============================================================================
# HOW TO GET AWS CREDENTIALS
# ============================================================================
# 1. Log into AWS Console: https://console.aws.amazon.com
# 2. Go to IAM → Users → Create User
# 3. User name: accessibility-agent-s3
# 4. Enable "Programmatic access"
# 5. Attach policy: AmazonS3FullAccess
# 6. Download credentials (AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY)
# 7. Paste them above
#
# 8. Create S3 Bucket:
#    - Go to S3 → Create Bucket
#    - Bucket name: accessibility-testing-reports (must be globally unique)
#    - Region: us-east-1 (or your preferred region)
#    - Block public access: ENABLED
#    - Create bucket
#
# 9. Set ENABLE_S3_STORAGE=true to activate
# ============================================================================

